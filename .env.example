# JARVIS Orchestration OS — 환경변수 설정
# .env 파일로 복사 후 실제 값을 입력하세요

# ─── Claude API ────────────────────────────────────────────
# Anthropic API 키 (https://console.anthropic.com 에서 발급)
ANTHROPIC_API_KEY=sk-ant-...

# ─── 서버 설정 ─────────────────────────────────────────────
# API 서버 포트 (기본값: 3001)
PORT=3001

# 프론트엔드 Vite 포트 (기본값: 5173)
VITE_PORT=5173

# ─── 데이터베이스 ─────────────────────────────────────────
# SQLite 감사 로그 파일 경로 (기본값: ./audit.db)
AUDIT_DB_PATH=./audit.db

# ─── 세션 관리 ─────────────────────────────────────────────
# 세션 TTL (분 단위, 기본값: 60)
SESSION_TTL_MINUTES=60

# Capability Token TTL (초 단위, 기본값: 300 = 5분)
CAPABILITY_TOKEN_TTL_SECONDS=300

# ─── 환경 ─────────────────────────────────────────────────
# 실행 환경 (development | production)
NODE_ENV=development

# ─── 로깅 ─────────────────────────────────────────────────
# 로그 레벨 (error | warn | info | debug)
LOG_LEVEL=info

# 감사 로그 마스킹 활성화 (true | false)
AUDIT_LOG_REDACTION_ENABLED=true

# ─── 신뢰 모드 ────────────────────────────────────────────
# 기본 신뢰 모드 (observe | suggest | semi-auto | full-auto)
DEFAULT_TRUST_MODE=suggest

# 완전 자율 모드 세션 시간 제한 (분, 기본값: 30)
FULL_AUTO_SESSION_LIMIT_MINUTES=30
