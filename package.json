{
  "name": "jarvis-orchestration-os",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "dev": "turbo run dev --filter=@jarvis/server --filter=@jarvis/web",
    "dev:server": "pnpm --filter @jarvis/server dev",
    "dev:web": "pnpm --filter @jarvis/web dev",
    "start": "node scripts/start.js",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "8.20.0",
    "@typescript-eslint/parser": "8.20.0",
    "eslint": "9.18.0",
    "prettier": "3.4.2",
    "turbo": "2.3.3",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "optionalDependencies": {
    "@esbuild/linux-x64": "0.24.2",
    "@rollup/rollup-win32-x64-msvc": "4.59.0"
  }
}
