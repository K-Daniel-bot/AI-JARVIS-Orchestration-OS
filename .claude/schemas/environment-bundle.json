            },
            "fallbackModelId": {
              "type": "string",
              "enum": [
                "claude-opus-4-6",
                "claude-sonnet-4-6",
                "claude-haiku-4-5"
              ],
              "description": "주 모델 실패 또는 한도 초과 시 대체 모델"
            },
            "costPerMToken": {
              "type": "number",
              "minimum": 0,
              "description": "백만 토큰당 비용 (USD) — 예산 계산용"
            }
          }
        }
