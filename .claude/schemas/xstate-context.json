{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://jarvis-os.local/schemas/xstate-context.v1.json",
  "title": "JarvisMachineContext",
  "description": "XState v5 상태 머신의 전체 런타임 컨텍스트 — 각 상태 전이마다 불변 업데이트(produce)로 관리",
  "version": "1.0.0",
  "last_updated": "2026-03-02",
  "engine": "XState v5",
  "type": "object",
  "required": [
    "runId",
    "sessionId",
    "userId",
    "userRole",
    "trustMode",
    "riskScore",
    "riskLevel",
    "capabilities",
    "timeline",
    "tokenBudget",
    "retryCount",
    "maxRetries",
    "loopCounter"
  ],
  "additionalProperties": false,
  "properties": {
    "runId": {
      "type": "string",
      "pattern": "^run_\\d{8}_\\d{4}$",
      "description": "실행 Run 고유 식별자 — run_{YYYYMMDD}_{seq4} 형식",
      "examples": ["run_20260302_0001"]
    },
    "sessionId": {
      "type": "string",
      "minLength": 1,
      "description": "사용자 세션 식별자 — 세션 전체를 하나의 단위로 추적"
    },
    "userId": {
      "type": "string",
      "minLength": 1,
      "description": "작업을 요청한 사용자 식별자"
    },
    "userRole": {
      "type": "string",
      "enum": ["Owner", "Admin", "User", "Guest"],
      "description": "사용자 역할 — PolicyDecision.subject.role과 동기화"
    },
    "trustMode": {
      "type": "string",
      "enum": ["observe", "suggest", "semi-auto", "full-auto"],
      "description": "현재 세션의 신뢰 모드 — 게이트 자동 통과 여부를 결정",
      "default": "suggest"
    },
    "currentAgent": {
      "type": "string",
      "enum": [
        "orchestrator",
        "spec-agent",
        "policy-risk",
        "planner",
        "codegen",
        "review",
        "test-build",
        "executor",
        "rollback"
      ],
      "description": "현재 활성 에이전트 — 상태 전이 시 업데이트"
    },
    "userInput": {
      "type": "string",
      "description": "사용자 원본 요청 텍스트 — SPEC_ANALYSIS 진입 시 설정"
    },
    "specRef": {
      "type": "string",
      "description": "SPEC.md 파일 경로 — spec-agent가 생성 후 설정",
      "examples": [".ai-run/SPEC.md"]
    },
    "planRef": {
      "type": "string",
      "description": "PLAN.json 파일 경로 — planner가 생성 후 설정",
      "examples": [".ai-run/PLAN.json"]
    },
    "policyDecision": {
      "$ref": "policy-decision.json#/PolicyDecision",
      "description": "현재 적용 중인 정책 판정 — policy-risk가 설정, 제약 조건으로 사용"
    },
    "changeSetRef": {
      "type": "string",
      "description": "CHANGES.json 파일 경로 — codegen이 생성 후 설정",
      "examples": [".ai-run/CHANGES.json"]
    },
    "reviewResult": {
      "$ref": "#/$defs/ReviewResult",
      "description": "코드 리뷰 결과 — review 에이전트가 설정"
    },
    "testResult": {
      "$ref": "#/$defs/TestResult",
      "description": "테스트 실행 결과 — test-build 에이전트가 설정"
    },
    "riskScore": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "현재 종합 위험도 점수 (0=안전, 100=위험) — policy-risk가 계산"
    },
    "riskLevel": {
      "type": "string",
      "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"],
      "description": "위험도 레벨 — riskScore 범위에서 도출 (0-39=LOW, 40-69=MEDIUM, 70-89=HIGH, 90-100=CRITICAL)"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^cap_\\d{8}_\\d{4}$"
      },
      "uniqueItems": true,
      "description": "현재 세션에서 발급된 활성 Capability Token ID 목록 — 소비 시 제거",
      "default": []
    },
    "timeline": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/TimelineEntry"
      },
      "description": "상태 전이 이력 — Append-only, 롤백 포인트 추적에 사용",
      "default": []
    },
    "tokenBudget": {
      "$ref": "#/$defs/TokenBudget",
      "description": "Claude API 토큰 사용량 추적 — 한도 초과 시 EMERGENCY_STOP"
    },
    "retryCount": {
      "type": "integer",
      "minimum": 0,
      "default": 0,
      "description": "현재 작업의 재시도 횟수 — maxRetries 초과 시 ERROR_RECOVERY로 전이"
    },
    "maxRetries": {
      "type": "integer",
      "minimum": 1,
      "default": 3,
      "description": "최대 재시도 허용 횟수 — 초과 시 Rollback 에이전트 호출"
    },
    "loopCounter": {
      "type": "integer",
      "minimum": 0,
      "default": 0,
      "description": "무한 루프 탐지 카운터 — PLAN→CODE→REVIEW→PLAN 사이클을 추적, 5회 초과 시 EMERGENCY_STOP"
    },
    "lastError": {
      "$ref": "#/$defs/JarvisError",
      "description": "마지막으로 발생한 에러 — ERROR_RECOVERY 진입 시 참조"
    },
    "checkpointRef": {
      "type": "string",
      "description": "현재 체크포인트 파일 경로 — 롤백 기준점",
      "examples": [".ai-run/checkpoints/cp_20260302_0001.json"]
    },
    "gateDecisions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/GateDecision"
      },
      "description": "게이트 승인/거부 이력 — 감사 목적으로 보관",
      "default": []
    }
  },
  "$defs": {
    "TimelineEntry": {
      "type": "object",
      "description": "단일 상태 전이 기록 — 상태 진입/탈출 시각과 담당 에이전트를 추적",
      "required": ["state", "enteredAt"],
      "additionalProperties": false,
      "properties": {
        "state": {
          "type": "string",
          "description": "XState 상태명 — state-machine.json의 States 키와 일치"
        },
        "enteredAt": {
          "type": "string",
          "format": "date-time",
          "description": "상태 진입 시각 (UTC ISO 8601)"
        },
        "exitedAt": {
          "type": "string",
          "format": "date-time",
          "description": "상태 탈출 시각 (UTC ISO 8601) — 진행 중이면 null"
        },
        "agentId": {
          "type": "string",
          "description": "해당 상태를 처리한 에이전트 ID"
        },
        "event": {
          "type": "string",
          "description": "이 상태에서 탈출을 유발한 이벤트명 (예: SPEC_COMPLETE)"
        },
        "durationMs": {
          "type": "number",
          "minimum": 0,
          "description": "상태 체류 시간 (밀리초) — exitedAt - enteredAt"
        },
        "tokensUsed": {
          "type": "integer",
          "minimum": 0,
          "description": "이 상태에서 소비된 Claude API 토큰 수"
        }
      }
    },
    "TokenBudget": {
      "type": "object",
      "description": "Claude API 토큰 예산 — 에이전트별 사용량 추적 포함",
      "required": ["used", "limit"],
      "additionalProperties": false,
      "properties": {
        "used": {
          "type": "integer",
          "minimum": 0,
          "description": "세션 전체 누적 사용 토큰 수"
        },
        "limit": {
          "type": "integer",
          "minimum": 1,
          "description": "세션 토큰 한도 — 초과 시 EMERGENCY_STOP 트리거"
        },
        "perAgent": {
          "type": "object",
          "description": "에이전트별 사용 토큰 맵 — 키: 에이전트ID, 값: 사용량",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "warningThreshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.8,
          "description": "경고 발생 임계값 (비율) — used/limit이 이 값 초과 시 오케스트레이터에 경고"
        }
      }
    },
    "ReviewResult": {
      "type": "object",
      "description": "코드 리뷰 결과 요약 — REVIEW_PASS / REVIEW_BLOCKERS 판정 근거",
      "required": ["status", "reviewedAt"],
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["PASS", "FAIL", "CONDITIONAL_PASS"],
          "description": "리뷰 최종 판정"
        },
        "reviewedAt": {
          "type": "string",
          "format": "date-time",
          "description": "리뷰 완료 시각"
        },
        "securityIssues": {
          "type": "array",
          "items": { "type": "string" },
          "description": "발견된 보안 이슈 목록 — BLOCKER 등급이면 FAIL"
        },
        "qualityIssues": {
          "type": "array",
          "items": { "type": "string" },
          "description": "코드 품질 이슈 목록"
        },
        "blockerCount": {
          "type": "integer",
          "minimum": 0,
          "description": "블로커 등급 이슈 수 — 1 이상이면 REVIEW_BLOCKERS 이벤트 발생"
        },
        "warningCount": {
          "type": "integer",
          "minimum": 0,
          "description": "경고 등급 이슈 수"
        }
      }
    },
    "TestResult": {
      "type": "object",
      "description": "테스트 실행 결과 — TEST_PASS / TEST_FAIL 판정 근거",
      "required": ["status", "testedAt"],
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["PASS", "FAIL", "SKIP"],
          "description": "테스트 최종 결과"
        },
        "testedAt": {
          "type": "string",
          "format": "date-time",
          "description": "테스트 완료 시각"
        },
        "totalTests": {
          "type": "integer",
          "minimum": 0,
          "description": "전체 테스트 케이스 수"
        },
        "passedTests": {
          "type": "integer",
          "minimum": 0,
          "description": "통과한 테스트 수"
        },
        "failedTests": {
          "type": "integer",
          "minimum": 0,
          "description": "실패한 테스트 수"
        },
        "coveragePercent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "코드 커버리지 백분율"
        },
        "buildSuccess": {
          "type": "boolean",
          "description": "TypeScript 컴파일 성공 여부"
        },
        "errorSummary": {
          "type": "string",
          "description": "실패 시 에러 요약 — Planner 재계획에 활용"
        }
      }
    },
    "JarvisError": {
      "type": "object",
      "description": "JARVIS OS 도메인 에러 — error-catalog.md의 에러 코드와 연계",
      "required": ["code", "message", "agentId", "occurredAt"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "AGENT_TIMEOUT",
            "VALIDATION_FAILED",
            "RESOURCE_EXHAUSTED",
            "INTERNAL_ERROR",
            "POLICY_VIOLATION",
            "CAPABILITY_EXPIRED",
            "BUILD_FAILED",
            "TEST_FAILED",
            "ROLLBACK_FAILED",
            "GATE_REJECTED"
          ],
          "description": "에러 코드 — error-catalog.md 참조"
        },
        "message": {
          "type": "string",
          "description": "에러 메시지 (시스템 경로/스택트레이스 미포함)"
        },
        "agentId": {
          "type": "string",
          "description": "에러가 발생한 에이전트 ID"
        },
        "occurredAt": {
          "type": "string",
          "format": "date-time",
          "description": "에러 발생 시각"
        },
        "retryable": {
          "type": "boolean",
          "default": false,
          "description": "재시도 가능 여부 — true면 retryCount 증가 후 재시도"
        },
        "context": {
          "type": "object",
          "description": "에러 컨텍스트 추가 정보 — 민감 데이터 제외",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "GateDecision": {
      "type": "object",
      "description": "게이트 승인/거부 기록 — 감사 로그와 연계",
      "required": ["gateId", "level", "decision", "decidedAt"],
      "additionalProperties": false,
      "properties": {
        "gateId": {
          "type": "string",
          "enum": [
            "GATE_PLAN_APPROVAL",
            "GATE_TOOL_APPROVAL",
            "GATE_APPLY_CHANGES",
            "GATE_DEPLOY",
            "GATE_WEB_PRECHECK",
            "GATE_DOWNLOAD",
            "GATE_DESTRUCTIVE",
            "GATE_PHONE_CONFIRM",
            "GATE_SMS_CONFIRM",
            "GATE_APP_ACCESS",
            "GATE_MESSENGER_READ"
          ],
          "description": "게이트 식별자 — state-machine.json의 SpecialGates와 일치"
        },
        "level": {
          "type": "string",
          "enum": ["L1", "L2", "L3"],
          "description": "게이트 등급 (L1=계획, L2=변경, L3=배포/실행)"
        },
        "decision": {
          "type": "string",
          "enum": ["APPROVED", "REJECTED", "SKIPPED", "TIMEOUT"],
          "description": "게이트 결정 결과"
        },
        "decidedAt": {
          "type": "string",
          "format": "date-time",
          "description": "결정 시각"
        },
        "decidedBy": {
          "type": "string",
          "enum": ["user", "auto"],
          "description": "결정 주체 — user(사용자 직접) 또는 auto(신뢰 모드 자동)"
        },
        "reason": {
          "type": "string",
          "description": "거부 또는 자동 승인 사유"
        }
      }
    }
  },

  "_examples": {
    "초기_컨텍스트": {
      "runId": "run_20260302_0001",
      "sessionId": "sess_abc123",
      "userId": "user_owner",
      "userRole": "Owner",
      "trustMode": "suggest",
      "riskScore": 0,
      "riskLevel": "LOW",
      "capabilities": [],
      "timeline": [],
      "tokenBudget": {
        "used": 0,
        "limit": 100000,
        "perAgent": {},
        "warningThreshold": 0.8
      },
      "retryCount": 0,
      "maxRetries": 3,
      "loopCounter": 0
    }
  }
}
